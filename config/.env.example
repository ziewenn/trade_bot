# Trading Mode — MUST default to "paper"
TRADING_MODE=paper

# Log level
LOG_LEVEL=INFO

# Polymarket (required for live mode only)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Binance (no auth needed — public WebSocket)

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk Parameters
INITIAL_BANKROLL=50.0
MAX_POSITION_PCT=0.02
DAILY_LOSS_LIMIT_PCT=0.03
DRAWDOWN_HALT_PCT=0.08
KELLY_FRACTION=0.25
MIN_EDGE_PCT=0.02
MAX_CONCURRENT_EXPOSURE_PCT=0.15

# Strategy Parameters
BINANCE_PRICE_LOOKBACK_MS=5000
MOMENTUM_THRESHOLD_PCT=0.0003
ORDER_OFFSET_CENTS=0.01
CANCEL_REPLACE_INTERVAL_MS=500
MARKET_ENTRY_WINDOW_SEC=240
MARKET_EXIT_BUFFER_SEC=30

# Stale Data Thresholds
STALE_BINANCE_THRESHOLD_S=5.0
STALE_POLYMARKET_THRESHOLD_S=10.0

# Volatility — BTC ~1.5% daily vol / sqrt(86400)
VOLATILITY_PER_SECOND=0.00005
